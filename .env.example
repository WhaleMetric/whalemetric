# ── Supabase (cliente público) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (service role) ──────────────────────────────────────────────────
# Sólo para scripts/tareas server-side privilegiadas.
SUPABASE_SERVICE_ROLE_KEY=

# ── API Python de workers locales ────────────────────────────────────────────
# Base URL del backend Flask expuesto vía Cloudflare Tunnel.
WORKERS_API_URL=https://api.whalemetric.com

# Bearer token que autentica todas las llamadas (marcar como "Sensitive"
# en la UI de Vercel). NUNCA commitear el valor real.
WORKERS_API_TOKEN=wm_replace_me_with_real_token
